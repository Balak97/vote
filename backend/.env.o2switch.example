# Copiez ce fichier en .env sur O2Switch (dans le dossier de l'app Python)
# Remplacez VOTRE_USER par votre identifiant cPanel (ex. qomo3546)

SECRET_KEY=remplacez-par-une-cle-aleatoire-longue
ADMIN_USERNAME=admin
ADMIN_PASSWORD=mot-de-passe-admin-fort
OTP_DEV_MODE=false
OTP_EXPIRE_MINUTES=5

# Email SMTP (O2Switch / cPanel)
EMAIL_HOST=mail.cantic-mali.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=techconceptde@cantic-mali.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-email
DEFAULT_FROM_EMAIL=techconceptde@cantic-mali.com

# Frontend (sous-domaine vote)
CORS_ORIGINS=["https://vote.cantic-mali.com"]

# MySQL — variables séparées (recommandé, pas d'encodage URL manuel)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=qomo3546_vote
DB_USER=qomo3546_Balako
DB_PASSWORD=votre-mot-de-passe-mysql

# Alternative : une seule URL (mot de passe spécial à encoder en URL)
# DATABASE_URL=mysql+aiomysql://qomo3546_Balako:motdepasse@localhost/qomo3546_vote

UPLOAD_DIR=/home/VOTRE_USER/api.vote.cantic-mali.com/uploads
