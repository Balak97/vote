{
  "name": "walata-vote-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-node.ps1 node_modules/vite/bin/vite.js",
    "build": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-node.ps1 node_modules/typescript/lib/tsc.js --noEmit && powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-node.ps1 node_modules/vite/bin/vite.js build",
    "preview": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-node.ps1 node_modules/vite/bin/vite.js preview"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.7.2",
    "vite": "^6.0.6"
  }
}
